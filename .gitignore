lib/
*.tsbuildinfo

# Test and coverage output
coverage/

# Logs and local environment
*.log
.env
.env.*

# Editor and OS noise
.DS_Store
.idea/
.vscode/

# Note: dist/ is intentionally NOT ignored. GitHub runs the committed bundle at
